<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Petstore API Test Suite" verbose="1">
    <!-- All API tests; run with: mvn test -->
    <test name="Pet CRUD - Positive">
        <classes>
            <class name="com.insider.petstore.api.tests.PetCrudPositiveTest"/>
        </classes>
    </test>
    <test name="Pet CRUD - Negative">
        <classes>
            <class name="com.insider.petstore.api.tests.PetCrudNegativeTest"/>
        </classes>
    </test>
    <test name="Pet API - Smoke">
        <classes>
            <class name="com.insider.petstore.api.tests.PetSmokeTest"/>
        </classes>
    </test>
</suite>
